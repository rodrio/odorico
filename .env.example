# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=false
SECRET_KEY=your-secret-key-here-change-in-production

# API Keys (add your actual keys here)
GOOGLE_API_KEY=your-google-api-key
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# External Tools for Oracle Agent
# SearchAPI.io (for web search tool)
SEARCHAPI_API_KEY=vLGAmaYQfkATmTLNA1kt8AnY

# LinkedIn API (for LinkedIn posting tool)
LINKEDIN_API_KEY=your-linkedin-api-key-here

# Meta API (for WhatsApp, Instagram, Facebook tools)
META_API_KEY=your-meta-api-key-here

# Render-specific
PORT=5000

# Session Security (for production)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
